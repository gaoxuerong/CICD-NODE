APP_PORT=80
LOG_LEVEL=info

# Keep observability private by default. Use SSH tunnel, VPN, or a protected reverse proxy.
OBSERVABILITY_BIND_ADDR=127.0.0.1
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
LOKI_PORT=3100
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-password

MYSQL_ROOT_PASSWORD=replace-with-a-long-random-password
DB_NAME=cicd
DB_USER=cicd
DB_PASSWORD=replace-with-a-long-random-password

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=7d
ENCRYPTION_KEY=replace-with-at-least-32-byte-secret
CORS_ORIGINS=https://your-domain.example
WEBHOOK_BASE_URL=https://your-domain.example
ENABLE_API_DOCS=false

# Required only when the production database is empty.
SEED_ADMIN_PASSWORD=replace-with-initial-admin-password
# Optional. Leave empty unless you explicitly want a demo developer account.
SEED_USER_PASSWORD=

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=cicd@example.com
SMTP_USERNAME=cicd@example.com
SMTP_PASSWORD=replace-with-smtp-password
ALERT_EMAIL_TO=ops@example.com

GLM_API_KEY=
